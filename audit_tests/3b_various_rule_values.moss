// Rules that produce different types of values to test trace formatting consistency
rule returnsNull() = null
rule returnsBool() = true
rule returnsList() = [1, 2, 3]
rule returnsRecord() = { x: 1, y: "hello" }
rule returnsMoney() = 42.usd

let _ = returnsNull()
let _ = returnsBool()
let _ = returnsList()
let _ = returnsRecord()
let _ = returnsMoney()

print("done")
