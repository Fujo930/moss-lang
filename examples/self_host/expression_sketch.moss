import "examples/self_host/expression_core.moss"

let parsed = parseExpressionSource("1 + 2 * 3 == 7")

print("expression kind:", parsed.expr.kind)
print("expression operator:", parsed.expr.value)
print("expression errors:", len(parsed.state.errors))

test "expression sketch builds structured precedence tree" {
  assert(len(parsed.state.errors) == 0, "expression should parse")
  assert(parsed.expr.kind == "Binary", "root should be binary")
  assert(parsed.expr.value == "==", "equality should be root")
  assert(parsed.expr.left.value == "+", "addition should be below equality")
  assert(parsed.expr.left.right.value == "*", "multiplication should bind tighter")

  grouped = parseExpressionSource("(1 + 2) * 3")
  assert(grouped.expr.value == "*", "multiplication should be root after grouping")
  assert(grouped.expr.left.value == "+", "grouped addition should stay together")

  unary = parseExpressionSource("not ready")
  assert(unary.expr.kind == "Unary", "not should produce unary expression")
  assert(unary.expr.right.value == "ready", "unary operand should be captured")

  broken = parseExpressionSource("(1 + 2")
  assert(len(broken.state.errors) == 1, "missing closing paren should be reported")

  call = parseExpressionSource("save(order.id, items[0])")
  assert(call.expr.kind == "Call", "call should produce call expression")
  assert(call.expr.left.value == "save", "call should retain callee")
  assert(len(call.expr.right) == 2, "call should capture arguments")
  assert(call.expr.right[0].kind == "Field", "first argument should be field access")
  assert(call.expr.right[0].value == "id", "field name should be captured")
  assert(call.expr.right[1].kind == "Index", "second argument should be index access")
  assert(call.expr.right[1].right.value == "0", "index expression should be captured")

  chained = parseExpressionSource("service.load()[0].name")
  assert(chained.expr.kind == "Field", "postfix expressions should chain")
  assert(chained.expr.value == "name", "last field should be root")

  logic = parseExpressionSource("ready and paid or override")
  assert(logic.expr.value == "or", "or should be the lowest precedence")
  assert(logic.expr.left.value == "and", "and should bind tighter than or")

  tried = parseExpressionSource("load(path)?.name")
  assert(tried.expr.kind == "Field", "field access should follow try")
  assert(tried.expr.left.kind == "Try", "question mark should produce try expression")
  assert(tried.expr.left.left.kind == "Call", "try should retain its operand")
}
